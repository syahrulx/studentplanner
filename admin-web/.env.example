# Copy this file to `.env.local` (git-ignored) and fill in values.
# `.env` / `.env.*` are git-ignored; only `.env.example` is committed.

# --- REQUIRED (public; safe to embed in client bundle) -----------------------
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# --- OPTIONAL (DEV ONLY — never set these in a production build) -------------
# When true, RequireAdmin bypasses the admin-users check so you can develop
# without signing in. This ONLY works when Vite's DEV flag is true. A safety
# check in `src/main.tsx` refuses to boot a production build that has this on.
VITE_BYPASS_ADMIN_AUTH=false

# When bypass is enabled above, API calls attach this as a Bearer token.
# It must match `ADMIN_WEB_DEV_SECRET` configured as a Supabase Edge secret.
# Anyone who has this string gets service-role access to every admin_* edge
# function, so keep it local, rotate it frequently, and DO NOT deploy with it.
# VITE_ADMIN_WEB_DEV_SECRET=
