<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="12dp"
  android:background="@color/gradeup_widget_bg">

  <TextView
    android:id="@+id/widget_greeting"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:textSize="15sp"
    android:textStyle="bold"
    android:textColor="@color/gradeup_widget_text_primary" />

  <TextView
    android:id="@+id/widget_tasks"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:textSize="13sp"
    android:textColor="@color/gradeup_widget_text_secondary"
    android:lineSpacingExtra="2dp"
    android:maxLines="10"
    android:ellipsize="end" />

  <TextView
    android:id="@+id/widget_classes"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:textSize="12sp"
    android:textColor="@color/gradeup_widget_text_tertiary"
    android:lineSpacingExtra="2dp"
    android:maxLines="10"
    android:ellipsize="end" />
</LinearLayout>
