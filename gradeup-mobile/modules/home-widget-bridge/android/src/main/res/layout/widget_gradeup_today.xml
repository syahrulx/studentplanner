<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="14dp"
  android:background="@color/gradeup_widget_bg">

  <!-- ─── HEADER ROW ─── -->
  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/gradeup_widget_text_primary" />

      <TextView
        android:id="@+id/widget_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/gradeup_widget_accent" />
    </LinearLayout>

    <TextView
      android:id="@+id/widget_count"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textSize="22sp"
      android:textStyle="bold"
      android:textColor="@color/gradeup_widget_accent"
      android:paddingStart="8dp"
      android:paddingEnd="4dp" />
  </LinearLayout>

  <!-- ─── HORIZONTAL DIVIDER ─── -->
  <View
    android:id="@+id/widget_divider"
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:background="@color/gradeup_widget_divider" />

  <!-- ─── SINGLE-TEXT FALLBACK (sign-in / stale / empty) ─── -->
  <TextView
    android:id="@+id/widget_message"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:textSize="12sp"
    android:textColor="@color/gradeup_widget_text_secondary"
    android:lineSpacingExtra="2dp"
    android:visibility="gone" />

  <!-- ─── TWO-COLUMN CONTENT ─── -->
  <LinearLayout
    android:id="@+id/widget_columns"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:orientation="horizontal"
    android:baselineAligned="false">

    <!-- TASKS COLUMN -->
    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:orientation="vertical"
      android:paddingEnd="10dp">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
          android:id="@+id/widget_tasks_label"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="TASKS"
          android:textSize="8sp"
          android:textStyle="bold"
          android:textColor="@color/gradeup_widget_accent"
          android:letterSpacing="0.08" />

        <TextView
          android:id="@+id/widget_tasks_count"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textSize="8sp"
          android:textStyle="bold"
          android:textColor="@color/gradeup_widget_text_muted" />
      </LinearLayout>

      <TextView
        android:id="@+id/widget_tasks_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/gradeup_widget_text_primary"
        android:lineSpacingExtra="4dp"
        android:maxLines="8"
        android:ellipsize="end" />
    </LinearLayout>

    <!-- VERTICAL DIVIDER -->
    <View
      android:id="@+id/widget_col_divider"
      android:layout_width="1dp"
      android:layout_height="match_parent"
      android:background="@color/gradeup_widget_divider" />

    <!-- CLASSES COLUMN -->
    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:orientation="vertical"
      android:paddingStart="10dp">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
          android:id="@+id/widget_classes_label"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="CLASSES"
          android:textSize="8sp"
          android:textStyle="bold"
          android:textColor="@color/gradeup_widget_accent"
          android:letterSpacing="0.08" />

        <TextView
          android:id="@+id/widget_classes_count"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textSize="8sp"
          android:textStyle="bold"
          android:textColor="@color/gradeup_widget_text_muted" />
      </LinearLayout>

      <TextView
        android:id="@+id/widget_classes_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/gradeup_widget_text_primary"
        android:lineSpacingExtra="4dp"
        android:maxLines="8"
        android:ellipsize="end" />
    </LinearLayout>

  </LinearLayout>
</LinearLayout>
