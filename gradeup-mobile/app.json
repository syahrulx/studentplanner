{
  "expo": {
    "name": "Rencana",
    "slug": "gradeup-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rencana",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aizztech.rencana",
      "appleTeamId": "Z9JR65SA89",
      "config": {
        "googleMapsApiKey": "AIzaSyBZmzDt1SISngjbNqI4N60BPWdeOr1fzpY"
      },
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"],
        "com.apple.security.application-groups": [
          "group.com.aizztech.rencana"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBZmzDt1SISngjbNqI4N60BPWdeOr1fzpY"
        }
      },
      "package": "com.aizztech.rencana"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#003366",
          "defaultChannel": "tasks"
        }
      ],
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.aizztech.rencana",
          "widgets": [
            {
              "name": "GradeUpToday",
              "displayName": "Today",
              "description": "Today’s tasks and timetable",
              "contentMarginsDisabled": false,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            },
            {
              "name": "GradeUpTasks",
              "displayName": "Tasks",
              "description": "Upcoming tasks",
              "contentMarginsDisabled": false,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "accessoryInline",
                "accessoryCircular",
                "accessoryRectangular"
              ]
            },
            {
              "name": "GradeUpTimetable",
              "displayName": "Timetable",
              "description": "Upcoming classes",
              "contentMarginsDisabled": false,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "accessoryInline",
                "accessoryCircular",
                "accessoryRectangular"
              ]
            }
          ]
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyBZmzDt1SISngjbNqI4N60BPWdeOr1fzpY"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
