{
  "expo": {
    "name": "Rencana",
    "slug": "gradeup-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rencana",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aizztech.rencana",
      "appleTeamId": "Z9JR65SA89",
      "config": {},
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"],
        "com.apple.security.application-groups": [
          "group.com.aizztech.rencana"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "config": {},
      "package": "com.aizztech.rencana"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#003366",
          "defaultChannel": "tasks"
        }
      ],
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.aizztech.rencana",
          "widgets": [
            {
              "name": "GradeUpToday",
              "displayName": "Today",
              "description": "Today’s tasks and timetable",
              "contentMarginsDisabled": false,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            },
            {
              "name": "GradeUpTasks",
              "displayName": "Tasks",
              "description": "Upcoming tasks",
              "contentMarginsDisabled": false,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "accessoryInline",
                "accessoryCircular",
                "accessoryRectangular"
              ]
            },
            {
              "name": "GradeUpTimetable",
              "displayName": "Timetable",
              "description": "Upcoming classes",
              "contentMarginsDisabled": false,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "accessoryInline",
                "accessoryCircular",
                "accessoryRectangular"
              ]
            }
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Rencana to use your location to provide personalized study reminders based on your campus presence.",
          "locationAlwaysPermission": "Allow Rencana to use your location in the background to detect when you are on campus.",
          "locationWhenInUsePermission": "Allow Rencana to use your location to show campus status.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "29240ff0-6a41-4552-bd3e-9b6b6ddf6b38"
      }
    }
  }
}
