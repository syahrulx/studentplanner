+  static func extractContainerBackground(from node: [String: Any]) -> Color {
+    guard
+      let props = node["props"] as? [String: Any],
+      let modifiers = props["modifiers"] as? [[String: Any]]
+    else {
+      return .black
+    }
+
+    for modifier in modifiers.reversed() {
+      guard let type = modifier["$type"] as? String, type == "background" else {
+        continue
+      }
+      guard let hex = modifier["color"] as? String else {
+        continue
+      }
+      return Self.colorFromHex(hex) ?? .black
+    }
+
+    return .black
+  }
+
+  static func colorFromHex(_ hex: String) -> Color? {
+    let normalized = hex.trimmingCharacters(in: CharacterSet.alphanumerics.inverted)
+    guard normalized.count == 6 || normalized.count == 8 else {
+      return nil
+    }
+    var int: UInt64 = 0
+    guard Scanner(string: normalized).scanHexInt64(&int) else {
+      return nil
+    }
+
+    let r: UInt64
+    let g: UInt64
+    let b: UInt64
+    let a: UInt64
+
+    if normalized.count == 8 {
+      r = (int >> 24) & 0xff
+      g = (int >> 16) & 0xff
+      b = (int >> 8) & 0xff
+      a = int & 0xff
+    } else {
+      r = (int >> 16) & 0xff
+      g = (int >> 8) & 0xff
+      b = int & 0xff
+      a = 255
+    }
+
+    return Color(
+      .sRGB,
+      red: Double(r) / 255.0,
+      green: Double(g) / 255.0,
+      blue: Double(b) / 255.0,
+      opacity: Double(a) / 255.0
+    )
+  }
