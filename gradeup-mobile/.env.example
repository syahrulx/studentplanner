# Supabase (optional – defaults are in app.config.js)
# Copy to .env.local to override.
EXPO_PUBLIC_SUPABASE_URL=https://ujxrtuogdialsrzxkcey.supabase.co
# Must be the anon JWT (starts with eyJ), not sb_publishable_*
LIC_SUPABASE_KEY=

# OpenAI – for generating flashcards from notes and quiz questions (see src/lib/studyApi.ts)
LIC_OPENAI_API_KEY=sk-your-openai-key
# Mapbox Access Token (for the university map view)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token-here

# Public HTTPS base for "Add friend" share links (must match site where you host
# AASA + landing page — see legal/aizztech-website/README.md)
# EXPO_PUBLIC_INVITE_HTTP_BASE=https://aizztech.com

# Google Classroom OAuth (direct Google flow, decoupled from Supabase auth).
# Create these in Google Cloud Console → APIs & Services → Credentials:
#   1. iOS client (type: iOS)   → Bundle ID: com.aizztech.rencana
#   2. Android client (type: Android) → Package: com.aizztech.rencana + keystore SHA-1(s)
#   3. Enable the Classroom API for the same project
# Do NOT put the *Web* client id in IOS or ANDROID — Google rejects custom URL schemes
# for web clients (error: "Custom scheme URIs are not allowed for 'WEB' client type").
# The app auto-injects the reversed iOS client id for CFBundleURLTypes.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxxxxxx-IOS-ONLY.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxxxxxx-ANDROID-ONLY.apps.googleusercontent.com
# Web client: Supabase "Sign in with Google" in browser (https redirect), not for Classroom in-app.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxxx-web.apps.googleusercontent.com